# Searchbox local/private default
AUTH_DISABLED=true
SEARCH_API_KEY=
RATE_LIMIT_PER_MINUTE=120

# Web search provider: serper, brave, or searxng
SEARCH_PROVIDER=searxng
SEARXNG_URL=http://127.0.0.1:8080
SEARXNG_RESULTS_LIMIT=50
SERPER_API_KEY=
BRAVE_API_KEY=

# Scientific retrieval
ADVANCED_SEARCH_ENABLED=true
ADVANCED_SEARCH_DEFAULT_SOURCE=auto
ADVANCED_SEARCH_AUTO_PROVIDER_ORDER=sciencestack,searchapi_scholar,serpapi_scholar,agentic_data,arxiv,oanor
ADVANCED_SEARCH_AUTO_MIN_PROVIDERS=2
ADVANCED_SEARCH_AUTO_MAX_PROVIDERS=5

# Science classifier
SCIENCE_CLASSIFIER_ENABLED=true
SCIENCE_CLASSIFIER_TIMEOUT=8
SCIENCE_CLASSIFIER_MAX_TOTAL_SECONDS=15
SCIENCE_CLASSIFIER_MAX_COMPLETION_TOKENS=1024
SCIENCE_CLASSIFIER_CONFIDENCE_THRESHOLD=0.55

# arXiv
ARXIV_API_URL=https://export.arxiv.org/api/query
ARXIV_USER_AGENT=Searchbox/0.1 (+https://github.com/searchbox/searchbox)
ARXIV_TIMEOUT=20
ARXIV_MAX_RESULTS=8
ARXIV_PDF_MAX_BYTES=26214400
ARXIV_CONTENT_SUMMARY_THRESHOLD_CHARS=5000
ARXIV_PAPER_SUMMARY_MAX_SOURCE_CHARS=120000
ARXIV_MIN_INTERVAL_SECONDS=3.2
ARXIV_DAILY_REQUEST_LIMIT=28800
ARXIV_COOLDOWN_SECONDS=300
ARXIV_MAX_RETRY_AFTER_SECONDS=1800

# Scientific paid/hosted providers
SCIENCESTACK_API_URL=https://sciencestack.ai/api/v1
SCIENCESTACK_API_KEY=
SCIENCESTACK_TIMEOUT=30
SCIENCESTACK_MAX_RESULTS=8
SCIENCESTACK_DAILY_REQUEST_LIMIT=100

SEARCHAPI_API_URL=https://www.searchapi.io/api/v1/search
SEARCHAPI_API_KEY=
SEARCHAPI_TIMEOUT=30
SEARCHAPI_MAX_RESULTS=8
SEARCHAPI_DAILY_REQUEST_LIMIT=100

SERPAPI_API_URL=https://serpapi.com/search.json
SERPAPI_API_KEY=
SERPAPI_TIMEOUT=30
SERPAPI_MAX_RESULTS=8
SERPAPI_DAILY_REQUEST_LIMIT=250
SERPAPI_MONTHLY_REQUEST_LIMIT=250

AGENTIC_DATA_ARXIV_URL=https://data.rag.ac.cn/arxiv/
AGENTIC_DATA_API_KEY=
AGENTIC_DATA_TIMEOUT=30
AGENTIC_DATA_MAX_RESULTS=8
AGENTIC_DATA_DAILY_REQUEST_LIMIT=10000

OANOR_ARXIV_API_URL=https://api.oanor.com/arxiv-api
OANOR_API_KEY=
OANOR_TIMEOUT=30
OANOR_MAX_RESULTS=8
OANOR_DAILY_REQUEST_LIMIT=3

# Persistent runtime state. Defaults are repo-relative if unset.
ADVANCED_PROVIDER_QUOTA_FILE=
ADVANCED_PROVIDER_MONTHLY_QUOTA_FILE=
ADVANCED_PROVIDER_COOLDOWN_FILE=
ADVANCED_PROVIDER_COOLDOWN_MAX_SECONDS=86400
SEARCHBOX_LOG_DIR=
LLM_ATTEMPT_LOG_FILE=
PROVIDER_EVENT_LOG_FILE=
SEARCHBOX_LOG_API_MAX_LINES=1000

# Fetch/extraction safety
MAX_FETCH_CONCURRENCY=5
MAX_REDIRECTS=5
BLOCK_PRIVATE_FETCH_IPS=true

# LLM settings are LiteLLM/OpenRouter-compatible and deployment-specific.
SUMMARIZER_ENABLED=true
OPENROUTER_API_KEY=
# Configure your provider keys and model names according to your chosen LLM provider.
LLM_MODEL=openrouter/openai/gpt-5-mini
OPENROUTER_MODEL_CHEAP=openrouter/qwen/qwen3-coder:free
OPENROUTER_MODEL_BALANCED=openrouter/openai/gpt-5-mini
LLM_FALLBACK_MODELS=openrouter/moonshotai/kimi-k2.6:free,openrouter/qwen/qwen3-coder:free
LLM_TIMEOUT=60
LLM_MAX_TOTAL_SECONDS=120
